# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
# Lokal MongoDB uchun:
MONGODB_URI=mongodb://localhost:27017/kvoice

# MongoDB Atlas uchun (quyidagilardan birini uncomment qiling):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/kvoice?retryWrites=true&w=majority

# CORS Configuration (Frontend URL'lar - vergul bilan ajratilgan)
# Development URLs
CORS_ORIGIN=http://localhost:5173,http://localhost:8080
# Production URLs (qo'shing):
# CORS_ORIGIN=http://localhost:5173,http://localhost:8080,https://kvoice.vercel.app,https://www.kvoice.vercel.app

# API Base URL
API_BASE_URL=http://localhost:3000

# Frontend URL
FRONTEND_URL=http://localhost:8080

