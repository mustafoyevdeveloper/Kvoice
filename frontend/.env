# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_API_BASE_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# App Configuration
VITE_APP_NAME=MovieMedia
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Eng yangi kinolar va seriallar
VITE_APP_URL=http://localhost:8080

# Environment
VITE_NODE_ENV=development
VITE_DEBUG_MODE=true

# Features
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PWA=true
VITE_ENABLE_OFFLINE_MODE=false
VITE_ENABLE_NOTIFICATIONS=true

# Upload Configuration
VITE_MAX_FILE_SIZE=500000000
VITE_ALLOWED_VIDEO_TYPES=video/mp4,video/avi,video/mov,video/wmv,video/mkv
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# UI Configuration
VITE_DEFAULT_THEME=dark
VITE_ITEMS_PER_PAGE=20
VITE_FEATURED_LIMIT=10
VITE_NEW_CONTENT_DAYS=7

# Language Configuration
VITE_DEFAULT_LANGUAGE=uz
VITE_SUPPORTED_LANGUAGES=uz,ru,en

# Cache Configuration
VITE_CACHE_TTL=3600000
VITE_CACHE_MAX_ITEMS=100

# Analytics Configuration
VITE_GOOGLE_ANALYTICS_ID=
VITE_GOOGLE_TAG_MANAGER_ID=
VITE_FACEBOOK_PIXEL_ID=

# Social Media Configuration
VITE_FACEBOOK_URL=https://facebook.com/moviemedia
VITE_INSTAGRAM_URL=https://instagram.com/moviemedia
VITE_TELEGRAM_URL=https://t.me/moviemedia
VITE_YOUTUBE_URL=https://youtube.com/moviemedia
VITE_TWITTER_URL=https://twitter.com/moviemedia
VITE_TIKTOK_URL=https://tiktok.com/@moviemedia

# Contact Information
VITE_CONTACT_EMAIL=contact@moviemedia.org
VITE_CONTACT_PHONE=+998 90 123 45 67
VITE_CONTACT_ADDRESS="Toshkent, O'zbekiston" ||

# Site Configuration
VITE_SITE_ICON=🎬
VITE_SITE_LOGO=
VITE_FAVICON=/MovieMedia favicon.png

# Section Names (Uzbek)
VITE_SECTION_PREMIERES=Premyeralar
VITE_SECTION_MOVIES=Kinolar
VITE_SECTION_SERIES=Seriallar
VITE_SECTION_TRAILERS=Treylerlar
VITE_SECTION_NEW=Yangi

# Section Titles (Uzbek)
VITE_SECTION_TITLE_PREMIERES=PREMYERALAR
VITE_SECTION_TITLE_MOVIES=KINOLAR
VITE_SECTION_TITLE_SERIES=SERIALLAR
VITE_SECTION_TITLE_TRAILERS=TREYLERLAR
VITE_SECTION_TITLE_NEW=YANGI KINOLAR

# Section Descriptions (Uzbek)
VITE_SECTION_DESC_PREMIERES=Issiq'ida tomosha qilib oling! Hammasi bizda!
VITE_SECTION_DESC_MOVIES=Eng yaxshi kinolar to'plami
VITE_SECTION_DESC_SERIES=Mashhur seriallar va multfilmlar
VITE_SECTION_DESC_TRAILERS=Eng so'nggi treylerlar
VITE_SECTION_DESC_NEW=Yangi qo'shilgan kinolar

# Hero Section
VITE_HERO_TITLE=Eng yaxshi kinolar va seriallar
VITE_HERO_SUBTITLE=O'zbek tilida eng yangi va mashhur kinolar

# About Page
VITE_ABOUT_TITLE=Biz haqimizda
VITE_ABOUT_DESCRIPTION=MovieMedia - kinolar va seriallar olamiga xush kelibsiz

# Privacy Policy
VITE_PRIVACY_TITLE=Maxfiylik siyosati
VITE_PRIVACY_DESCRIPTION=Sizning shaxsiy ma'lumotlaringiz biz uchun muhim

# Terms of Service
VITE_TERMS_TITLE=Foydalanish shartlari
VITE_TERMS_DESCRIPTION=Saytdan foydalanish shartlari va qoidalari

# SEO Configuration
VITE_SEO_TITLE=MovieMedia - Eng yaxshi kinolar va seriallar
VITE_SEO_DESCRIPTION=O'zbek tilida eng yangi va mashhur kinolar, seriallar va treylerlar
VITE_SEO_KEYWORDS=kinolar, seriallar, treylerlar, o'zbek, online, tomosha

# Performance Configuration
VITE_LAZY_LOADING=true
VITE_IMAGE_OPTIMIZATION=true
VITE_VIDEO_PRELOAD=metadata
VITE_INFINITE_SCROLL=true

# Security Configuration
VITE_CSP_ENABLED=true
VITE_XSS_PROTECTION=true
VITE_CSRF_PROTECTION=true

# Development Configuration
VITE_HOT_RELOAD=true
VITE_DEV_TOOLS=true
VITE_MOCK_API=false
VITE_LOG_LEVEL=info

# Build Configuration
VITE_BUILD_SOURCEMAP=true
VITE_BUILD_MINIFY=true
VITE_BUILD_COMPRESS=true

# PWA Configuration
VITE_PWA_NAME=MovieMedia
VITE_PWA_SHORT_NAME=MovieMedia
VITE_PWA_DESCRIPTION=Eng yangi kinolar va seriallar
VITE_PWA_THEME_COLOR=#3b82f6
VITE_PWA_BACKGROUND_COLOR=#000000
VITE_PWA_DISPLAY=standalone
VITE_PWA_ORIENTATION=portrait
VITE_PWA_START_URL=/
VITE_PWA_SCOPE=/

# Notification Configuration
VITE_NOTIFICATION_ENABLED=true
VITE_NOTIFICATION_PERMISSION=default
VITE_NOTIFICATION_ICON=/MovieMedia favicon.png

# Offline Configuration
VITE_OFFLINE_ENABLED=false
VITE_OFFLINE_CACHE_STRATEGY=cacheFirst
VITE_OFFLINE_CACHE_SIZE=50

# Error Handling
VITE_ERROR_REPORTING=true
VITE_ERROR_BOUNDARY=true
VITE_ERROR_FALLBACK=true

# Testing Configuration
VITE_TEST_MODE=false
VITE_MOCK_DATA=false
VITE_DEBUG_ANALYTICS=false
